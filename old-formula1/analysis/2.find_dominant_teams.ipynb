   "source": [
    "select team_name, count(1) as total_races, sum(calculated_points) as total_points, avg(calculated_points) as avg_points \n",
    "from f1_presentation.calculated_race_results \n",
    "group by team_name \n",
    "having count(1) >= 50\n",
    "order by avg_points desc"
   ]
